      -H "Authorization: Bearer $LM_API_TOKEN" \
      -H "Content-Type: application/json" \
      -d '{
        "model": "ibm/granite-4-micro",
        "input": "Open lmstudio.ai",
        "integrations": ["mcp/playwright"],
        "context_length": 8000,
        "temperature": 0
      }'
    ```
  </CodeBlockTab>

  <CodeBlockTab value="Python">
    ```python
